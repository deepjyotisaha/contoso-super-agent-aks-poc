# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# Azure OpenAI resource base URL (without path or api-version)
# Found in: Azure Portal → your OpenAI resource → Keys and Endpoint → Endpoint
# Format: https://<resource-name>.cognitiveservices.azure.com/
#      or https://<resource-name>.openai.azure.com/
AZURE_AI_ENDPOINT_URL=https://<your-resource-name>.cognitiveservices.azure.com/

# Azure OpenAI API key
# Found in: Azure Portal → your OpenAI resource → Keys and Endpoint → KEY 1 or KEY 2
AZURE_AI_API_KEY=<your-api-key>

# Deployment name (as shown in Azure AI Foundry → Deployments)
AZURE_AI_MODEL=gpt-4o

# API version — use the version matching your deployment
AZURE_AI_API_VERSION=2024-05-01-preview

# System prompt sent to the model before each user message (optional)
AZURE_AI_SYSTEM_PROMPT=You are a helpful assistant. Answer the user's question clearly and concisely.
